#!/bin/sh
#/ script/lint runs linters on the project.

set -e

CDPATH="" cd -- "$(dirname -- "$0")/.."

script/bootstrap
script/bindown -q install shellcheck
script/bindown -q install zizmor

# Skip non-script artifacts in src/ (e.g. goversion-select.version,
# a bare release tag written by the release-train pre-tag hook,
# or directories like testdata/).
src_files=""
for f in ./src/*; do
  case "$f" in
    *.version) continue ;;
  esac
  [ -d "$f" ] && continue
  src_files="$src_files $f"
done

# shellcheck disable=SC2086  # intentional word-splitting on src_files
bin/shellcheck -e SC1071 -x ./script/* $src_files ./.github/workflows/script/*
bin/zizmor --no-progress .github/workflows/
