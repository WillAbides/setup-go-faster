#!/bin/bash
#/ release pre-tag hook for release-train:
#/   1. cross-compile tools/goversion-select for every goos/goarch combo
#/      that setup-go-faster supports and stage the binaries in
#/      $ASSETS_DIR so release-train uploads them as release assets;
#/   2. substitute the VERSION placeholder in src/goversion-select with
#/      $RELEASE_TAG, commit the substitution, and create the release tag
#/      locally — release-train picks up the hook-created tag and uses it
#/      as the release target. The vN major branch advances to that commit
#/      via advance-major-branch, so customers pinning `@vN` get a
#/      wrapper with the real tag baked in.
#/
#/ The wrapper on main keeps "__VERSION__" so CI (uses: ./) and any
#/ checkout off main builds from source instead of downloading.

set -euo pipefail

: "${ASSETS_DIR:?must be set by release-train}"
: "${RELEASE_TAG:?must be set by release-train}"

CDPATH="" cd -- "$(dirname -- "$0")/../../.."

.github/workflows/script/cross-compile-goversion-select

shim="src/goversion-select"
sed -i.bak -E "s|^VERSION=\"__VERSION__\"\$|VERSION=\"${RELEASE_TAG}\"|" "$shim"
rm "${shim}.bak"
if ! grep -qx "VERSION=\"${RELEASE_TAG}\"" "$shim"; then
  echo "release-pre-tag: failed to substitute VERSION in $shim" >&2
  exit 1
fi

git add "$shim"
git commit -m "release: bake $RELEASE_TAG into $shim"
git tag "$RELEASE_TAG"
